<Page x:Class="TheAllocator.Pages.BackupSelectDestinationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="*" />
            <RowDefinition Height="18" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock FontSize="30" FontWeight="Bold" Text="Select Backup Destination" />
            <TextBlock Margin="0,10,0,0"
                       FontSize="16"
                       Foreground="{StaticResource AllocatorMutedBrush}"
                       TextWrapping="Wrap"
                       Text="Choose the external drive or transfer folder where the backup package should be created." />
        </StackPanel>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="0.9*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock FontSize="20" FontWeight="Bold" Text="Destination" />
                    <TextBlock Margin="0,12,0,0"
                               FontSize="15"
                               Foreground="{StaticResource AllocatorMutedBrush}"
                               TextWrapping="Wrap"
                               Text="The archive, backup details file, printers file, text log, and logs folder will all be created here. A drive-level telemetry queue is also maintained automatically." />
                    <TextBox x:Name="DestinationTextBox"
                             Margin="0,14,0,0"
                             VerticalContentAlignment="Center"
                             TextChanged="DestinationTextBox_TextChanged" />
                    <Button Margin="0,14,0,0"
                            HorizontalAlignment="Left"
                            MinWidth="132"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Click="Browse_Click"
                            Content="Browse..." />
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock FontSize="20" FontWeight="Bold" Text="Files That Will Be Created" />
                    <TextBlock x:Name="OutputSummaryText"
                               Margin="0,16,0,0"
                               FontSize="15"
                               TextWrapping="Wrap" />
                    <TextBlock x:Name="CompressionSummaryText"
                               Margin="0,14,0,0"
                               FontSize="14"
                               Foreground="{StaticResource AllocatorMutedBrush}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Style="{StaticResource SecondaryButtonStyle}" Click="Back_Click" Content="Back" />
            <Button Grid.Column="2"
                    x:Name="NextButton"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Click="Next_Click"
                    Content="Next"
                    IsEnabled="False" />
        </Grid>
    </Grid>
</Page>
