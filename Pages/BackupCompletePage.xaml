<Page x:Class="TheAllocator.Pages.BackupCompletePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="*" />
            <RowDefinition Height="18" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock FontSize="30" FontWeight="Bold" Text="Backup Complete 🍕" />
            <TextBlock Margin="0,10,0,0"
                       FontSize="16"
                       Foreground="{StaticResource AllocatorMutedBrush}"
                       TextWrapping="Wrap"
                       Text="The old computer path is complete. Move the backup package to the new computer and start the restore branch there." />
        </StackPanel>

        <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}">
            <StackPanel>
                <TextBlock FontSize="20" FontWeight="Bold" Text="Package Ready" />
                <TextBlock x:Name="CompleteText"
                           Margin="0,16,0,0"
                           FontSize="15"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Style="{StaticResource SecondaryButtonStyle}" Click="StartOver_Click" Content="Back To Start" />
            <Button Grid.Column="2"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Click="Exit_Click"
                    Content="Exit" />
        </Grid>
    </Grid>
</Page>
