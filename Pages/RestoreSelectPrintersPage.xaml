<Page x:Class="TheAllocator.Pages.RestoreSelectPrintersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="*" />
            <RowDefinition Height="18" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock FontSize="30" FontWeight="Bold" Text="Select Printers To Restore" />
            <TextBlock Margin="0,10,0,0"
                       FontSize="16"
                       Foreground="{StaticResource AllocatorMutedBrush}"
                       TextWrapping="Wrap"
                       Text="Choose whether all saved printers should be restored or if some should be skipped on the new computer." />
        </StackPanel>

        <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="14" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock FontSize="15"
                           Foreground="{StaticResource AllocatorMutedBrush}"
                           TextWrapping="Wrap"
                           Text="These printers were read from the backup package. Keep the ones you want recreated on the new computer checked." />

                <ListBox x:Name="PrintersListBox"
                         Grid.Row="2"
                         MinHeight="0"
                         ItemContainerStyle="{StaticResource CompactPrinterItemStyle}"
                         PreviewKeyDown="PrintersListBox_PreviewKeyDown"
                         BorderThickness="0"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                      Style="{StaticResource CompactPrinterCheckBoxStyle}">
                                <StackPanel>
                                    <TextBlock FontSize="14" FontWeight="SemiBold" Text="{Binding Name}" />
                                    <TextBlock Margin="0,3,0,0"
                                               FontSize="12"
                                               Foreground="{StaticResource AllocatorMutedBrush}"
                                               TextWrapping="Wrap"
                                               Text="{Binding ConnectionPath, StringFormat=Connection: {0}}" />
                                    <TextBlock Margin="0,2,0,0"
                                               FontSize="12"
                                               Foreground="{StaticResource AllocatorMutedBrush}"
                                               TextWrapping="Wrap"
                                               Text="{Binding PortName, StringFormat=Port: {0}}" />
                                    <TextBlock Margin="0,2,0,0"
                                               FontSize="12"
                                               Foreground="{StaticResource AllocatorMutedBrush}"
                                               TextWrapping="Wrap"
                                               Text="{Binding DriverName, StringFormat=Driver: {0}}" />
                                </StackPanel>
                            </CheckBox>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Style="{StaticResource SecondaryButtonStyle}" Click="Back_Click" Content="Back" />
            <Button Grid.Column="2" Style="{StaticResource PrimaryButtonStyle}" Click="Next_Click" Content="Next" />
        </Grid>
    </Grid>
</Page>
