<Page x:Class="TheAllocator.Pages.BackupSelectPrintersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="*" />
            <RowDefinition Height="18" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock FontSize="30" FontWeight="Bold" Text="Select Printers" />
            <TextBlock Margin="0,10,0,0"
                       FontSize="16"
                       Foreground="{StaticResource AllocatorMutedBrush}"
                       TextWrapping="Wrap"
                       Text="Select the printer connections that should be saved alongside this user's backup." />
        </StackPanel>

        <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock x:Name="PrintersSummaryText"
                           FontSize="15"
                           Foreground="{StaticResource AllocatorMutedBrush}"
                           Text="Looking for installed printers..." />

                <ListBox x:Name="PrintersListBox"
                         Grid.Row="2"
                         MinHeight="0"
                         ItemContainerStyle="{StaticResource CompactPrinterItemStyle}"
                         PreviewKeyDown="PrintersListBox_PreviewKeyDown"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.CanContentScroll="True"
                         BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                      Style="{StaticResource CompactPrinterCheckBoxStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock FontSize="14"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"
                                               Text="{Binding Name}" />
                                    <TextBlock Grid.Column="1"
                                               Margin="16,0,0,0"
                                               FontSize="13"
                                               Foreground="{StaticResource AllocatorMutedBrush}"
                                               VerticalAlignment="Center"
                                               Text="{Binding IsDefault, StringFormat=Default: {0}}" />
                                </Grid>
                            </CheckBox>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Style="{StaticResource SecondaryButtonStyle}" Click="Back_Click" Content="Back" />
            <Button Grid.Column="2" Style="{StaticResource PrimaryButtonStyle}" Click="Next_Click" Content="Next" />
        </Grid>
    </Grid>
</Page>
