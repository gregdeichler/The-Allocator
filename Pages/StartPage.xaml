<Page x:Class="TheAllocator.Pages.StartPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent">
    <Grid>
        <Grid VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="24" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="56" />
                        <RowDefinition Height="18" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="24" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock FontSize="28"
                               FontWeight="Bold"
                               Text="Old Computer" />
                    <TextBlock Grid.Row="1"
                               VerticalAlignment="Top"
                               FontSize="16"
                               Foreground="{StaticResource AllocatorMutedBrush}"
                               TextWrapping="Wrap"
                               Text="Create the backup package from the source machine." />

                    <Border Grid.Row="3"
                            Style="{StaticResource StepCardStyle}">
                        <StackPanel>
                            <TextBlock FontSize="15" Text="Select User" />
                            <TextBlock Margin="0,8,0,0" FontSize="15" Text="Select Printers" />
                            <TextBlock Margin="0,8,0,0" FontSize="15" Text="Start Backup" />
                        </StackPanel>
                    </Border>

                    <Button Grid.Row="6"
                            HorizontalAlignment="Left"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="OldComputer_Click"
                            Content="Old Computer" />
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="56" />
                        <RowDefinition Height="18" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="24" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock FontSize="28"
                               FontWeight="Bold"
                               Text="New Computer" />
                    <TextBlock Grid.Row="1"
                               VerticalAlignment="Top"
                               FontSize="16"
                               Foreground="{StaticResource AllocatorMutedBrush}"
                               TextWrapping="Wrap"
                               Text="Open a backup package and restore it onto the destination machine." />

                    <Border Grid.Row="3"
                            Style="{StaticResource StepCardStyle}">
                        <StackPanel>
                            <TextBlock FontSize="15" Text="Select Backup File" />
                            <TextBlock Margin="0,8,0,0" FontSize="15" Text="Choose Target Account" />
                            <TextBlock Margin="0,8,0,0" FontSize="15" Text="Start Restore" />
                        </StackPanel>
                    </Border>

                    <Button Grid.Row="6"
                            HorizontalAlignment="Left"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="NewComputer_Click"
                            Content="New Computer" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
