<Page x:Class="TheAllocator.Pages.RestoreCompletePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="*" />
            <RowDefinition Height="18" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock FontSize="30" FontWeight="Bold" Text="Restore Complete" />
            <TextBlock Margin="0,10,0,0"
                       FontSize="16"
                       Foreground="{StaticResource AllocatorMutedBrush}"
                       TextWrapping="Wrap"
                       Text="The restore path is complete. Review the summary below before signing into the restored account." />
        </StackPanel>

        <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock FontSize="20" FontWeight="Bold" Text="Restore Summary" />
                <ScrollViewer Grid.Row="2"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              CanContentScroll="True">
                    <TextBlock x:Name="CompleteText"
                               FontSize="15"
                               TextWrapping="Wrap" />
                </ScrollViewer>
            </Grid>
        </Border>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Style="{StaticResource SecondaryButtonStyle}" Click="StartOver_Click" Content="Back To Start" />
            <Button Grid.Column="2"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Click="RebootComputer_Click"
                    Content="Reboot Computer" />
        </Grid>
    </Grid>
</Page>
