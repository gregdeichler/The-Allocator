<Page x:Class="TheAllocator.Pages.BackupReviewPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="*" />
            <RowDefinition Height="18" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock FontSize="30" FontWeight="Bold" Text="Review and Start Backup" />
            <TextBlock Margin="0,10,0,0"
                       FontSize="16"
                       Foreground="{StaticResource AllocatorMutedBrush}"
                       TextWrapping="Wrap"
                       Text="Confirm the selected user, selected printers, and destination before the backup package is created." />
        </StackPanel>

        <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}">
            <StackPanel>
                <TextBlock FontSize="20" FontWeight="Bold" Text="Backup Summary" />
                <TextBlock x:Name="SummaryText"
                           Margin="0,16,0,0"
                           FontSize="15"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Style="{StaticResource SecondaryButtonStyle}" Click="Back_Click" Content="Back" />
            <Button Grid.Column="2"
                    x:Name="BeginButton"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Click="Begin_Click"
                    Content="Begin Backup"
                    IsEnabled="False" />
        </Grid>
    </Grid>
</Page>
