<Page x:Class="TheAllocator.Pages.RestoreSelectBackupFilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="*" />
            <RowDefinition Height="18" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock FontSize="30" FontWeight="Bold" Text="Select Backup File" />
            <TextBlock Margin="0,10,0,0"
                       FontSize="16"
                       Foreground="{StaticResource AllocatorMutedBrush}"
                       TextWrapping="Wrap"
                       Text="Choose the backup package that came from the old computer." />
        </StackPanel>

        <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}">
            <StackPanel>
                <TextBlock FontSize="15"
                           Foreground="{StaticResource AllocatorMutedBrush}"
                           TextWrapping="Wrap"
                           Text="The app will read the matching backup details automatically when they are available beside or inside the archive." />
                <TextBox x:Name="BackupFileTextBox" Margin="0,16,0,0" />
                <Button Margin="0,14,0,0"
                        HorizontalAlignment="Left"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Click="Browse_Click"
                        Content="Browse" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Style="{StaticResource SecondaryButtonStyle}" Click="Back_Click" Content="Back" />
            <Button Grid.Column="2"
                    x:Name="NextButton"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Click="Next_Click"
                    Content="Next"
                    IsEnabled="False" />
        </Grid>
    </Grid>
</Page>
