<Page x:Class="TheAllocator.Pages.RestoreSelectTargetUserPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="*" />
            <RowDefinition Height="18" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock FontSize="30" FontWeight="Bold" Text="Choose Sign-In Account" />
            <TextBlock Margin="0,10,0,0"
                       FontSize="16"
                       Foreground="{StaticResource AllocatorMutedBrush}"
                       TextWrapping="Wrap"
                       Text="Choose who will sign into this restored profile. You can use an existing account on this computer or enter one manually." />
        </StackPanel>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="0.9*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock FontSize="20" FontWeight="Bold" Text="Use An Existing Account" />
                    <TextBlock Margin="0,10,0,0"
                               FontSize="14"
                               Foreground="{StaticResource AllocatorMutedBrush}"
                               TextWrapping="Wrap"
                               Text="Choose an account that already exists on this computer." />
                    <RadioButton x:Name="UseExistingAccountRadioButton"
                                 Margin="0,14,0,0"
                                 Content="Use selected existing account"
                                 Checked="AccountMode_Checked" />
                    <ListBox x:Name="ProfilesListBox"
                             Margin="0,16,0,0"
                             SelectionChanged="ProfilesListBox_SelectionChanged"
                             DisplayMemberPath="DisplayName"
                             MinHeight="0"
                             BorderThickness="0"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled" />
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock FontSize="20" FontWeight="Bold" Text="Enter An Account" />
                    <TextBlock Margin="0,10,0,0"
                               FontSize="14"
                               Foreground="{StaticResource AllocatorMutedBrush}"
                               TextWrapping="Wrap"
                               Text="Use this if the account is not already listed on this computer." />
                    <RadioButton x:Name="EnterAccountRadioButton"
                                 Margin="0,14,0,0"
                                 Content="Enter account manually"
                                 IsChecked="True"
                                 Checked="AccountMode_Checked" />
                    <TextBox x:Name="TargetUserTextBox"
                             Margin="0,16,0,0"
                             TextChanged="TargetUserTextBox_TextChanged" />
                    <CheckBox x:Name="DomainAccountCheckBox"
                              Margin="0,14,0,0"
                              IsChecked="True"
                              Checked="DomainAccountCheckBox_Changed"
                              Unchecked="DomainAccountCheckBox_Changed"
                              Content="Domain account (ad.vassar.edu)" />
                    <TextBlock Margin="0,12,0,0"
                               FontSize="14"
                               Foreground="{StaticResource AllocatorMutedBrush}"
                               TextWrapping="Wrap"
                               Text="When domain account is checked, the app will treat the typed username as an ad.vassar.edu account. Turn it off for a local account." />
                    <TextBlock x:Name="ResolvedAccountText"
                               Margin="0,12,0,0"
                               FontSize="14"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Style="{StaticResource SecondaryButtonStyle}" Click="Back_Click" Content="Back" />
            <Button Grid.Column="2"
                    x:Name="NextButton"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Click="Next_Click"
                    Content="Next"
                    IsEnabled="False" />
        </Grid>
    </Grid>
</Page>
